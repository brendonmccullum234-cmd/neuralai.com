function detectMode(text) {
  const t = text.toLowerCase();
  if (t.includes("```") || t.includes("function") || t.includes("import") || t.includes("def ")) return ["💻 Coding", "#22d3ee"];
  if (t.includes("explain") || t.includes("what is") || t.includes("how does") || t.includes("study")) return ["📚 Study", "#a78bfa"];
  if (t.includes("business") || t.includes("strategy") || t.includes("market")) return ["💼 Business", "#34d399"];
  if (t.includes("story") || t.includes("poem") || t.includes("creative")) return ["🎨 Creative", "#f472b6"];
  return ["⚡ Quick", "#fbbf24"];
}

function renderMD(raw) {
  return raw
    .replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;")
    .replace(/```(\w*)\n?([\s\S]*?)```/g, (_,lang,code)=>
      `<div class="cb"><div class="cl">${lang||"code"}</div><pre><code>${code.trim()}</code></pre></div>`)
    .replace(/`([^`]+)`/g,'<code class="ic">$1</code>')
    .replace(/\*\*(.+?)\*\*/g,"<strong>$1</strong>")
    .replace(/^### (.+)$/gm,'<h3>$1</h3>')
    .replace(/^## (.+)$/gm,'<h2>$1</h2>')
    .replace(/^# (.+)$/gm,'<h1>$1</h1>')
    .replace(/^[-*] (.+)$/gm,'<li>$1</li>')
    .replace(/(<li>[\s\S]*?<\/li>\n?)+/g, m=>`<ul>${m}</ul>`)
    .replace(/\n\n/g,"<br/><br/>")
    .replace(/\n/g,"<br/>");
}

