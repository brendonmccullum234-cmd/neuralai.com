        .md .cb{background:#080810;border:1px solid rgba(255,255,255,0.1);border-radius:10px;overflow:hidden;margin:10px 0;}
        .md .cl{padding:5px 14px;font-size:10.5px;color:#6366f1;font-family:monospace;background:rgba(99,102,241,0.07);border-bottom:1px solid rgba(255,255,255,0.06);text-transform:uppercase;letter-spacing:0.06em;}
