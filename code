        @keyframes pulse{0%,100%{box-shadow:0 0 6px rgba(52,211,153,0.5);}50%{box-shadow:0 0 14px rgba(52,211,153,0.9);}}
        .md h1,.md h2,.md h3{color:#f0f0f8;font-weight:600;margin:10px 0 5px;}
